{
  "name": "thanos-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:thanos": "cd ../.. && GOCACHE=/private/tmp/thanos-go-build GOMODCACHE=/private/tmp/thanos-go-mod go build -o bin/thanos ./cmd/thanos",
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "tauri": "npm run build:thanos && tauri",
    "tauri:dev": "npm run build:thanos && tauri dev",
    "tauri:build": "npm run build:thanos && tauri build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-query": "^5.90.12",
    "@tauri-apps/api": "^2.11.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-resizable-panels": "^3.0.6",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
