{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Thanos Desktop UI",
  "version": "0.1.0",
  "identifier": "dev.thanos.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Thanos Desktop UI",
        "width": 1180,
        "height": 780,
        "minWidth": 860,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
